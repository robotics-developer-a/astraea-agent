# ─── Provider 选择 ───────────────────────────────────────
# PROVIDER=anthropic  (默认)
# PROVIDER=ollama
# PROVIDER=openai

# ─── Anthropic（云端）─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Ollama（本地）────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1   (默认)
# OLLAMA_MODEL=qwen2.5:7b                    (默认)

# ─── OpenAI（云端）────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o                        (默认)
# OPENAI_BASE_URL=https://api.openai.com/v1  (默认，可改为中转地址)

# ─── 联网搜索（配一个即可） ──────────────────────────────────
#
# 💡 最简单的方式：进入 Astraea 后直接运行 /internet 向导，
#    选 provider、粘贴 Key 即可，自动存到 ~/.astraea/.env。
#
# ⚠️  API key 属于个人 secret，建议放在 ~/.astraea/.env（全局）
#     而不是这个项目级 .env，这样所有 Astraea 项目都能复用，
#     也不会因为误提交 git 而泄漏。
#
# 手动全局配置方式：
#   mkdir -p ~/.astraea
#   echo "BOCHA_API_KEY=sk-xxx" >> ~/.astraea/.env
#
# 【国内直连·推荐】博查 Bocha（专为 AI 设计，按量付费，无需代理）
# 注册：https://open.bochaai.com
# BOCHA_API_KEY=sk-xxxxxxxxxxxxx

# 【国内直连】智谱 BigModel（可复用已有智谱 Key，无需代理）
# 注册：https://open.bigmodel.cn
# ZHIPU_API_KEY=xxxxxxxxxxxxx
# ZHIPU_SEARCH_ENGINE=search_std    # 可选：search_std（默认）| search_pro

# Tavily（1,000次/月，无信用卡，专为 AI Agent 设计，需代理）
# 注册：https://app.tavily.com/sign-up
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# Brave Search（2,000次/月，需代理）
# 注册：https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=BSA-xxxxxxxxxxxxx

# Exa 语义搜索（1,000次/月，适合研究类查询，需代理）
# 注册：https://dashboard.exa.ai
# EXA_API_KEY=xxxxxxxxxxxxx

# 强制指定适配器（默认 auto 自动探测：博查→智谱→Brave→Tavily→Exa）
# ASTRAEA_SEARCH_ADAPTER=bocha
