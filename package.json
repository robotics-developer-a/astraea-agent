  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "ink": "^7.0.3",
    "ink-text-input": "^6.0.0",
    "marked": "^18.0.4",
    "openai": "^6.38.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "turndown": "^7.2.4"
  }
